{
  "name": "webpack-template",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "webpack --config webpack.prod.js",
    "dev": "webpack serve --config webpack.dev.js",
    "pages": "git branch gh-pages",
    "merge:pages": "git checkout gh-pages && git merge main --no-edit",
    "commit:dist": "git add dist/ -f && git commit -m 'Deployment commit'",
    "deploy": "git subtree push --prefix dist origin gh-pages",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run format && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Asunder3301/webpack-template.git"
  },
